/// @description Wstaw opis w tym miejscu
// W tym edytorze możesz zapisać swój kod



replay = false;
replay_timeline = [];
replay_timeline_index = 0;

move_left = function(){
	x -= 1;
}

move_right = function(){
	x += 1;
}

move_up = function(){
	y -= 1;
}

move_down = function(){
	y += 1;
}

wait = function(){};
